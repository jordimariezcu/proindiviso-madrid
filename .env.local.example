# Resend - para emails al abogado
# Crea cuenta gratis en resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxx

# Email del abogado donde llegan los leads
ABOGADO_EMAIL=abogado@tudespacho.com

# Supabase - para guardar leads en base de datos
# Crea proyecto gratis en supabase.com
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyxxxxxxxxxxxxxxxx

# Teléfono del abogado (con prefijo internacional)
NEXT_PUBLIC_TELEFONO=+34600000000

# En producción (Vercel) añade estas mismas variables en
# Settings > Environment Variables
